# ============================================
# SUPABASE CONFIGURATION (Required)
# ============================================
# Get these from: Supabase Dashboard > Project Settings > API
# WARNING: Only use the anon/public key. NEVER use service_role key in frontend code.
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_KEY=your-anon-key-here

# ============================================
# GOOGLE OAUTH FOR ADMIN LOGIN (Required)
# ============================================
# This is REQUIRED for admin panel access. Without it, you cannot log in.
#
# HOW TO GET GOOGLE CLIENT ID:
# 1. Go to: https://console.cloud.google.com/
# 2. Create a new project or select existing
# 3. Go to "APIs & Services" > "Credentials"
# 4. Click "Create Credentials" > "OAuth client ID"
# 5. Application type: "Web application"
# 6. Add authorized JavaScript origins:
#    - For development: http://localhost:5173
#    - For production: https://your-domain.com
# 7. Copy the Client ID and paste it below
#
# Format: xxxxxxxx.apps.googleusercontent.com
VITE_GOOGLE_CLIENT_ID=YOUR_GOOGLE_CLIENT_ID_HERE.apps.googleusercontent.com

# ============================================
# GITHUB CDN FOR PRODUCT IMAGES (Required)
# ============================================
# GitHub repository for hosting product images
VITE_GITHUB_OWNER=YourGitHubUser
VITE_GITHUB_REPO=YourRepoName
VITE_CDN_BRANCH=cdn

# ============================================
# APPLICATION SETTINGS (Optional)
# ============================================
VITE_APP_NAME=BhumiShop Admin
VITE_APP_ENV=development
# Base URL for deployment (e.g., /BhumiAdm/ for GitHub Pages)
# Leave as / for root deployment
VITE_BASE_URL=/
